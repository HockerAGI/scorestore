# =========================================================
# Force LF in text files (evita CRLF rompiendo bash/shebang)
# =========================================================
* text=auto eol=lf

# Scripts
*.sh text eol=lf
*.py text eol=lf

# Web
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.md   text eol=lf
*.xml  text eol=lf

# SQL
*.sql  text eol=lf