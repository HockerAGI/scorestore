# =========================================================
# Force LF in text files (evita CRLF rompiendo bash/shebang)
# =========================================================
* text=auto eol=lf

# Scripts
*.sh text eol=lf
*.py text eol=lf

# Web
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.webmanifest text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.toml text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binary assets (no tocar line endings)
*.png  binary
*.jpg  binary
*.jpeg binary
*.webp binary
*.gif  binary
*.svg  binary
*.ico  binary
*.pdf  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.otf  binary
