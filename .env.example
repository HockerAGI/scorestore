# =========================================================
# SCORE STORE — Environment Variables (.env.example)
# NO subas secretos reales al repositorio en GitHub.
# Configúralos en Netlify: Site settings -> Environment variables
# =========================================================

# URL base (Netlify la inyecta, pero puedes forzarla aquí para desarrollo local)
SITE_URL=https://scorestore.netlify.app

# -------------------------
# Stripe (Checkout + Webhook)
# -------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# 1 = habilita OXXO en Checkout (si tu cuenta Stripe lo tiene activado)
STRIPE_ENABLE_OXXO=1

# -------------------------
# Envía.com (Cotizador Logístico + Guías Automáticas)
# -------------------------
ENVIA_ENV=prod
ENVIA_API_KEY=

# Carriers por defecto activados en el dashboard de Envía.com
ENVIA_MX_DEFAULT_CARRIER=dhl
ENVIA_US_DEFAULT_CARRIER=usps

# Paridad Cambiaria si Envía regresa tarifas en USD
ENVIA_FORCE_USD_TO_MXN=0
FX_USD_TO_MXN=18

# Token de seguridad para el Webhook de Envía (Recomendado)
ENVIA_WEBHOOK_TOKEN=

# -------------------------
# Origen Logístico (Remitente Oficial)
# -------------------------
ORIGIN_MX_NAME=Score Store MX
ORIGIN_MX_COMPANY=Único Uniformes
ORIGIN_MX_EMAIL=contacto.hocker@gmail.com
ORIGIN_MX_PHONE=6642368701
ORIGIN_MX_STREET=Palermo
ORIGIN_MX_NUMBER=6106 Interior JK
ORIGIN_MX_DISTRICT=Anexa Roma
ORIGIN_MX_CITY=Tijuana
ORIGIN_MX_STATE=Baja California
ORIGIN_MX_POSTAL=22614
ORIGIN_MX_RFC=BAJ220613P51
ORIGIN_MX_REFERENCE=Cerca de las antenas

ORIGIN_US_NAME=Score Store US
ORIGIN_US_COMPANY=Score Store
ORIGIN_US_EMAIL=ventas.unicotexti@gmail.com
ORIGIN_US_PHONE=8180000000
ORIGIN_US_STREET=Main St
ORIGIN_US_NUMBER=1
ORIGIN_US_DISTRICT=Other
ORIGIN_US_CITY=San Diego
ORIGIN_US_STATE=CA
ORIGIN_US_POSTAL=92101
ORIGIN_US_REFERENCE=

# -------------------------
# Dimensiones Volumétricas (Para cálculo preciso en Checkout)
# -------------------------
PACK_WEIGHT_KG=1
PACK_L_CM=30
PACK_W_CM=25
PACK_H_CM=10

PACK_WEIGHT_LB=1
PACK_L_IN=11
PACK_W_IN=15
PACK_H_IN=20

# -------------------------
# Contingencia (Fallback si API de Envía colapsa)
# -------------------------
FALLBACK_MX_PRICE_MXN=250
FALLBACK_US_PRICE_MXN=850
FALLBACK_PER_ITEM_MXN=50

# -------------------------
# Notificaciones Telegram a Staff (Opcional)
# -------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -------------------------
# Base de Datos (Integración UnicOs Admin)
# -------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -------------------------
# SCORE AI (Asistente Virtual con Gemini)
# -------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# -------------------------
# Marketing
# -------------------------
META_PIXEL_ID=
FACEBOOK_DOMAIN_VERIFICATION=wuo7x5sxsjcer1t0epn1id5xgjp8su