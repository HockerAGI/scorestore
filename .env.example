# NO subas secretos al repo. Configúralos en Netlify -> Site settings -> Environment variables.

SITE_URL=https://scorestore.netlify.app

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Opcional: habilita OXXO en Checkout (si tu cuenta Stripe lo soporta)
STRIPE_ENABLE_OXXO=0

# Envia.com (cotizador + guía)
ENVIA_API_KEY=
# Opcionales (si quieres fijar carrier/servicio)
ENVIA_CARRIER=carriers/dhl
ENVIA_SERVICE=services/nacional_standard
# Opcional (proteger webhook)
ENVIA_WEBHOOK_TOKEN=

# Telegram (opcional) — alertas de pago
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Supabase (para guardar órdenes + tracking)
SUPABASE_URL=https://lpbzndnavkbpxwnlbqgb.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini (Score AI)
GEMINI_API_KEY=
