ORIGIN_MX_NUMBER=6106 Interior JK
ORIGIN_MX_DISTRICT=Anexa Roma
ORIGIN_MX_CITY=Tijuana
ORIGIN_MX_STATE=Baja California
ORIGIN_MX_POSTAL=22614
ORIGIN_MX_RFC=BAJ220613P51
ORIGIN_MX_REFERENCE=Cerca de las antenas

ORIGIN_US_NAME=Score Store US
ORIGIN_US_COMPANY=Score Store
