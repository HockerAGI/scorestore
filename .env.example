# Fallback envíos
FALLBACK_MX_PRICE_MXN=250
FALLBACK_US_PRICE_MXN=850
FALLBACK_PER_ITEM_MXN=50

# Telegram (opcional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Supabase (funciones)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Org default (Multi-tenant / UnicOs)
SCORE_ORG_ID=1f3b9980-a1c5-4557-b4eb-a75bb9a8aaa6

# SCORE AI (Gemini)
